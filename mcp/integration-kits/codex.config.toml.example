# AgentGangGang starter kit for Codex MCP configuration.
# Copy the block you need into your own Codex config.toml and adjust the
# absolute repository path if your clone lives elsewhere.

[mcp_servers.agentganggang]
command = "npm"
args = ["run", "mcp:server"]
cwd = "/absolute/path/to/agentganggang"

# Suggested first calls after the server is attached:
# 1. agentganggang.bridge_status
# 2. agentganggang.check_readiness
# 3. agentganggang.compare
# 4. agentganggang.analyze_compare
# 5. agentganggang.run_workflow
