# Optional selector override source.
# Leave empty to use the built-in selector map only.
VITE_SELECTOR_CONFIG_URL=

# Login-state-sensitive live/browser flows use the repo-owned persistent Chrome root.
# Default:
# AGENTGANGGANG_BROWSER_USER_DATA_DIR=~/.cache/agentganggang/browser/chrome-user-data
# AGENTGANGGANG_BROWSER_PROFILE_NAME=agentganggang
AGENTGANGGANG_BROWSER_USER_DATA_DIR=
AGENTGANGGANG_BROWSER_PROFILE_NAME=

# Optional explicit Chrome profile directory override.
# When set, this takes precedence over AGENTGANGGANG_BROWSER_PROFILE_NAME.
AGENTGANGGANG_BROWSER_PROFILE_DIRECTORY=

# Optional explicit Google Chrome executable override.
AGENTGANGGANG_BROWSER_EXECUTABLE_PATH=

# Optional browser-window identity hints for the repo-owned live lane.
# These control the generated local identity tab opened by test:live:open-browser.
AGENTGANGGANG_BROWSER_IDENTITY_LABEL=
AGENTGANGGANG_BROWSER_IDENTITY_ACCENT=

# One-time bootstrap source.
# Default source root:
# AGENTGANGGANG_BROWSER_SOURCE_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
# Default source profile name:
# AGENTGANGGANG_BROWSER_SOURCE_PROFILE_NAME=agentganggang
AGENTGANGGANG_BROWSER_SOURCE_USER_DATA_DIR=
AGENTGANGGANG_BROWSER_SOURCE_PROFILE_NAME=
AGENTGANGGANG_BROWSER_SOURCE_PROFILE_DIRECTORY=

# Repo-owned external cache governance.
# Default root: ~/.cache/agentganggang
# Default cap: 2147483648 bytes (2 GB)
# Default ttl: 72 hours
# Note: ~/.cache/agentganggang/browser/chrome-user-data is persistent browser
# state and is excluded from ttl/cap pruning.
AGENTGANGGANG_EXTERNAL_CACHE_ROOT=
AGENTGANGGANG_EXTERNAL_CACHE_MAX_BYTES=
AGENTGANGGANG_EXTERNAL_CACHE_TTL_HOURS=

# Optional live-lane overrides.
AGENTGANGGANG_LIVE_CDP_URL=
AGENTGANGGANG_LIVE_CDP_PORT=
AGENTGANGGANG_LIVE_BROWSER_CHANNEL=
AGENTGANGGANG_LIVE_ATTACH_MODE=
