{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["prompt-switchboard-opencode-plugin"],
  "mcp": {
    "prompt_switchboard": {
      "type": "local",
      "command": [
        "npm",
        "--prefix",
        "/absolute/path/to/AgentGangGang",
        "run",
        "mcp:server"
      ],
      "enabled": true
    }
  }
}
